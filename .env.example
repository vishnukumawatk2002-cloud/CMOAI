# ── Production overrides (uncomment for deploy) ─────────────
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://app.cmoai.com
# LOG_CHANNEL=daily
# LOG_LEVEL=warning
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

# PayU payment gateway
# PAYU_MERCHANT_KEY=
# PAYU_MERCHANT_SALT=
# PAYU_BASE_URL=https://test.payu.in/_payment

# X / Twitter OAuth (https://developer.x.com)
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_REDIRECT_URI="${APP_URL}/onboarding/social/x/callback"

# LinkedIn OAuth (https://www.linkedin.com/developers)
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI="${APP_URL}/onboarding/social/linkedin/callback"

# YouTube Shorts OAuth (Google Cloud — enable YouTube Data API v3)
# Reuses GOOGLE_CLIENT_ID/SECRET if YOUTUBE_* not set
# YOUTUBE_REDIRECT_URI="${APP_URL}/onboarding/social/youtube/callback"
# FFMPEG_PATH= # optional absolute path to ffmpeg.exe (image/carousel → YouTube video)

# Snapchat Public Profile OAuth (create app in Snapchat Ads Manager, not Developer Portal)
# SNAPCHAT_CLIENT_ID=
# SNAPCHAT_CLIENT_SECRET=
# SNAPCHAT_REDIRECT_URI="${APP_URL}/onboarding/social/snapchat/callback"
